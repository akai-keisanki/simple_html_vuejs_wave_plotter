<!DOCTYPE html>
<html>
  <head>
    <title>Simple HTML+Vue.js Wave Plotter</title>
    <meta encoding=utf-8>
    <script src=https://unpkg.com/vue@3></script>
  </head>
  <body>
    <main id="app">
      {{wavelength}}
      <wave-plot :wavelength=wavelength :amplitude=amplitude :frequencyHz=frequencyHz>
      <input type=number v-model=wavelength>
      <input type=number v-model=amplitude>
      <input type=number v-model=frequencyHz>
    </main>
    <script>
      const { createApp, ref } = Vue

      const app = createApp({
        setup = () => ({
          wavelength: ref(2),
          amplitude: ref(1),
          frequencyHz: ref(1)
        })
      })

      app.component('wavePlot', {
        template: `
          <>
        `,
        props: {
          wavelength: { type: Number, required: true },
          amplitude: { type: Number, required: true },
          wavelengthHz: { type: Number, required: true }
        },
        setup = () => {
        }
      })

      app.mount('#app')
    </script>
  </body>
</html>
